---
// src/pages/blog/[...slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: ReturnType<typeof getCollection<'blog'>>[number];
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('pt-BR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};
---

<BaseLayout 
  title={`${post.data.title} - Luis Menardi`}
  description={post.data.summary}
>
  <Header />
  <main class="post-detail">
    <article class="container post-detail__content">
      <div class="post-detail__header">
        <a href="/blog" class="post-detail__back">← Voltar</a>
        <h1>{post.data.title}</h1>
        <div class="post-detail__meta">
          <time>{formatDate(post.data.date)}</time>
          <span class="post-detail__category">{post.data.category}</span>
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-detail__tags">
            {post.data.tags.map((tag) => (
              <span class="tag-badge">{tag}</span>
            ))}
          </div>
        )}
      </div>

      {post.data.cover && (
        <img 
          src={post.data.cover} 
          alt={post.data.title}
          class="post-detail__cover"
        />
      )}

      <div class="post-detail__body">
        <Content />
      </div>

      <nav class="post-detail__nav">
        <a href="/blog" class="btn btn--secondary">Ver todos os posts</a>
      </nav>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .post-detail {
    padding: var(--space-12) var(--space-8);
  }

  .post-detail__content {
    max-width: 800px;
  }

  .post-detail__back {
    display: inline-block;
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-8);
    transition: color var(--transition-fast);
  }

  .post-detail__back:hover {
    color: var(--color-accent-hover);
  }

  .post-detail__header {
    margin-bottom: var(--space-12);
  }

  .post-detail__header h1 {
    margin-bottom: var(--space-6);
    font-family: var(--font-display);
  }

  .post-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .post-detail__category {
    display: inline-block;
    background-color: var(--color-accent-muted);
    color: var(--color-accent);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
  }

  .post-detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .tag-badge {
    display: inline-block;
    background-color: var(--color-surface);
    color: var(--color-text-primary);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    border: 1px solid var(--color-border);
  }

  .post-detail__cover {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-16);
  }

  .post-detail__body {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-16);
  }

  .post-detail__body :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    color: var(--color-text-primary);
    font-family: var(--font-display);
  }

  .post-detail__body :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .post-detail__body :global(p) {
    margin-bottom: var(--space-6);
  }

  .post-detail__body :global(ul),
  .post-detail__body :global(ol) {
    margin-left: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .post-detail__body :global(li) {
    margin-bottom: var(--space-3);
  }

  .post-detail__body :global(code) {
    background-color: var(--color-surface);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .post-detail__body :global(pre) {
    background-color: var(--color-surface);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }

  .post-detail__body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: var(--space-6);
    margin-left: 0;
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post-detail__nav {
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (max-width: 768px) {
    .post-detail {
      padding: var(--space-8) var(--space-6);
    }

    .post-detail__meta {
      flex-wrap: wrap;
      gap: var(--space-4);
    }
  }
</style>
