---
// src/pages/sobre.astro
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout title="Sobre - Luis Menardi" description="Conheça Luis Menardi, especialista em Design Systems e Product Design.">
  <Header />
  <main class="sobre">
    <article class="container sobre__content">
      <div class="sobre__header">
        <div class="sobre__image">
          <img src="/images/about-me/IMG_4644-min.png" alt="Luis Menardi selfie at Config event" />
        </div>
        <div class="sobre__info">
          <h1>Hi, I'm Luis!</h1>
          <p class="sobre__description">
            Sou um Product Designer com foco em Design Systems, especializado em criar soluções escaláveis que unem design, engenharia e estratégia. Trabalho na intersecção entre design e tecnologia, criando experiências e sistemas que fazem diferença.
          </p>
          <p class="sobre__specialty">Design Systems • Product Designer • Design Engineer</p>
        </div>
      </div>

      
      <section class="sobre__section">
        <h2>Main competences</h2>
        <ul class="sobre__values">
          <li><strong>Systemic thinking:</strong> my solutions always aim for scalability, reuse and large scale impact.</li>
          <li><strong>Collaboration:</strong> I gather people with me so we can all think together on the 
          solution for the challenges we are facing.</li>
          <li><strong>Continuous learning:</strong> technology is evolving quickly, there's always something new to learn
          and I'm passionate about it.</li>
        </ul>
      </section>

      <section class="sobre__section">
        <h2>Career</h2>
        <div class="sobre__timeline">
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Senior Product Designer</h3>
              <p class="company-name">Itaú Unibanco</p>
            </div>
            <p class="timeline-date">Jul 2025 - Current</p>
            <p>Works in the Design System team, is responsible for creating and maintaining the Design System's design 
            tokens and themes, support core components team create and maintaining and documenting components. Also, 
            is responsible to explore the application of AI in the design process in the DS team.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Analyst Product Designer</h3>
              <p class="company-name">iFood</p>
            </div>
            <p class="timeline-date">Jun 2023 - Jun 2025</p>
            <p>Worked in the Design System & Ops team, is responsible for creating and maintaining Design System
             components, support iFood's design team, create and maintaining documentations for components
              and team processes in order to create standards and to increase the consistency of iFood's products.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Lead Product Designer</h3>
              <p class="company-name">World Bank Group</p>
            </div>
            <p class="timeline-date">Jan 2022 - Jun 2025</p>
            <p>Product Designer on a World Bank Group's project that aimed to create the 
            <a href="https://coachdigital.org/np/docs/docs/code/intro/">"Coach Digital" app</a> in collaboration 
            with the governments of Sierra Leone and Nepal.
            <br>The main goal was to improve the quality of education in these countries through technology and data 
            by the digitalization of a pedagogical material created by the WBG and provide visibility to those governments
            of the current state of the education.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Product Designer</h3>
              <p class="company-name">Savings Collaborative</p>
            </div>
            <p class="timeline-date">Jan 2022 - Jun 2025</p>
            <p>Worked on the design team focused on creating experiences for the Savings Collaborative app 
            and its administrative panel, making it easier for users to develop healthy financial habits in the USA.
            <br>Was responsible for making discoveries, user testing, create, maintaining and documenting user flows 
            and creating creative solutions based on data.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Junior Product Designer</h3>
              <p class="company-name">iFood</p>
            </div>
            <p class="timeline-date">Jan 2022 - Jun 2023</p>
            <p>Worked in the Design System & Ops team, responsible for creating and maintaining Design System 
            components and flows.
            <br>Was responsible for tokens restructuring projects, documentation standardization, typographic 
            font changes, discovery process about designers and developers' contribution and satisfaction 
            with the Design System.</p>
          </div>
          <div class="timeline-item">
            <div class="timeline-item-header">
              <h3>Intern Product Designer</h3>
              <p class="company-name">iFood</p>
            </div>
            <p class="timeline-date">Jan 2021 - Jan 2022</p>
            <p>Worked in the Design System & Ops team, responsible for creating and maintaining Design System 
            components and flows.
            <br>In the Design Ops team, assisted the maintenance of the Design System and the management of 
            design teams, also co-created the design accessibility meetup.
            <br>As an internship conclusion work, was responsible for the project to create an accessibility 
            guide for digital products.</p>
          </div>
        </div>
      </section>

    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .sobre {
    padding: var(--space-12) var(--space-8);
  }

  .sobre__content {
    max-width: 800px;
  }

  .sobre__header {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-12);
    margin-bottom: var(--space-20);
    align-items: center;
  }

  .sobre__image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3/4;
    background-color: var(--color-surface);
  }

  .sobre__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sobre__info h1 {
    margin-bottom: var(--space-2);
  }

  .sobre__specialty {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .sobre__description {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }

  .sobre__section {
    margin-bottom: var(--space-16);
  }

  .sobre__section h2 {
    margin-bottom: var(--space-8);
  }

  .sobre__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .timeline-item {
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-accent);
  }

  .timeline-item-header {
    display: flex;
    flex-direction: row;
    gap: var(--space-3);
    align-items: center;
  }

  .company-name {
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
  }

  .timeline-date {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .sobre__values {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sobre__values li {
    padding: var(--space-4);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .sobre {
      padding: var(--space-8) var(--space-6);
    }

    .sobre__header {
      grid-template-columns: 1fr;
    }

    .sobre__image {
      aspect-ratio: 1/1;
    }

    .timeline-item-header {
      flex-direction: column;
      align-items: start;
    }
  }
</style>
