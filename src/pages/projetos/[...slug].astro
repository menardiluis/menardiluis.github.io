---
// src/pages/projetos/[...slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: ReturnType<typeof getCollection<'projects'>>[number];
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout 
  title={`${project.data.title} - Luis Menardi`}
  description={project.data.summary}
>
  <Header />
  <main class="project-detail">
    <article class="container project-detail__content">
      <div class="project-detail__header">
        <a href="/projetos" class="project-detail__back">← Voltar</a>
        <h1>{project.data.title}</h1>
        <div class="project-detail__meta">
          <span class="project-detail__company">{project.data.company}</span>
          <span class="project-detail__year">{project.data.year}</span>
          <span class="project-detail__role">{project.data.role}</span>
          <span class="project-detail__duration">{project.data.duration}</span>
        </div>
        <div class="project-detail__categories">
          {project.data.categories.map((category) => (
            <span class="category-badge">{category}</span>
          ))}
        </div>
      </div>

      <img 
        src={project.data.cover} 
        alt={project.data.title}
        class="project-detail__cover"
      />

      <div class="project-detail__body">
        <Content />
      </div>

      <nav class="project-detail__nav">
        <a href="/projetos" class="btn btn--secondary">Ver todos os projetos</a>
      </nav>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-detail {
    padding: var(--space-12) var(--space-8);
  }

  .project-detail__content {
    max-width: 900px;
  }

  .project-detail__back {
    display: inline-block;
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-8);
    transition: color var(--transition-fast);
  }

  .project-detail__back:hover {
    color: var(--color-accent-hover);
  }

  .project-detail__header {
    margin-bottom: var(--space-12);
  }

  .project-detail__header h1 {
    margin-bottom: var(--space-6);
    font-family: var(--font-display);
  }

  .project-detail__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .project-detail__company,
  .project-detail__year,
  .project-detail__role,
  .project-detail__duration {
    display: inline-block;
  }

  .project-detail__company::after,
  .project-detail__year::after,
  .project-detail__role::after {
    content: ' •';
    margin-left: var(--space-4);
    opacity: 0.5;
  }

  .project-detail__categories {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .category-badge {
    display: inline-block;
    background-color: var(--color-accent-subtle);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .project-detail__cover {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-16);
  }

  .project-detail__body {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-16);
  }

  .project-detail__body :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    color: var(--color-text-primary);
    font-family: var(--font-display);
  }

  .project-detail__body :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .project-detail__body :global(p) {
    margin-bottom: var(--space-6);
  }

  .project-detail__body :global(ul),
  .project-detail__body :global(ol) {
    margin-left: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .project-detail__body :global(li) {
    margin-bottom: var(--space-3);
  }

  .project-detail__body :global(code) {
    background-color: var(--color-surface);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .project-detail__body :global(pre) {
    background-color: var(--color-surface);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }

  .project-detail__body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: var(--space-6);
    margin-left: 0;
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .project-detail__nav {
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (max-width: 768px) {
    .project-detail {
      padding: var(--space-8) var(--space-6);
    }

    .project-detail__meta {
      gap: var(--space-2);
    }

    .project-detail__company::after,
    .project-detail__year::after,
    .project-detail__role::after {
      margin-left: var(--space-2);
    }

    .project-detail__categories {
      gap: var(--space-2);
    }

    .category-badge {
      font-size: var(--font-size-xs);
    }
  }
</style>
