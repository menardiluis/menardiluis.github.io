---
// src/components/layout/Header.astro
import MobileMenu from '@components/ui/MobileMenu.jsx';
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo"><span style=
    "font-weight: var(--font-weight-light)">luis</span>menardi</a>
    <nav class="header__nav">
      <a href="/" class="header__link">Home</a>
      <a href="/sobre" class="header__link">Sobre</a>
      <a href="/projetos" class="header__link">Projetos</a>
      <a href="/blog" class="header__link">Blog</a>
    </nav>
    <MobileMenu client:load />
  </div>
</header>

<style>
  .header {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-8);
  }

  .header__logo {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .header__logo:hover {
    color: var(--color-accent-hover);
  }

  .header__nav {
    display: flex;
    gap: var(--space-8);
    align-items: center;
  }

  .header__link {
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .header__link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }

    .header__link {
      font-size: var(--font-size-sm);
    }
  }
</style>
