---
// src/components/home/WorkWithMe.astro
---

<section class="work-with-me">
  <div class="container">
    <div class="work-with-me__content">
      <h2>Trabalhe comigo</h2>
      <p>
        Disponível para projetos de Design Systems, Product Design e consultoria de Design Engineering. Aceito trabalhos em tempo integral, consultoria e projetos pontuais.
      </p>
      <a href="mailto:luisfelipemenardi@gmail.com" class="btn btn--primary">
        luisfelipemenardi@gmail.com
      </a>
    </div>
  </div>
</section>

<style>
  .work-with-me {
    background-color: var(--color-surface);
    padding: var(--space-20) var(--space-8);
  }

  .work-with-me__content {
    max-width: 600px;
    text-align: center;
  }

  .work-with-me__content h2 {
    margin-bottom: var(--space-6);
  }

  .work-with-me__content p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--line-height-relaxed);
    font-size: var(--font-size-md);
  }
</style>
